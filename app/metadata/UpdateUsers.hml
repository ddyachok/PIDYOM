  typeName: UsersSetInput
  permissions:
    - role: admin
      output:
        allowedFields:
          - createdAt
          - email
          - id
          - name

---
kind: ObjectType
version: v1
definition:
  name: UpdateUsersResult
  description: update from users result
  fields:
    - name: affectedRows
      type: Int32!
      description: Number of affected rows
    - name: returning
      type: "[Users!]!"
      description: Objects that were affected by update
  graphql:
    typeName: UpdateUsersResult
    inputTypeName: UpdateUsersResultInput
  dataConnectorTypeMapping:
    - dataConnectorName: my_pg
      dataConnectorObjectType: update_users_result
      fieldMapping:
        affectedRows:
          column:
            name: affected_rows
        returning:
          column:
            name: returning

---
kind: TypePermissions
version: v1
definition:
  typeName: UpdateUsersResult
  permissions:
    - role: admin
      output:
        allowedFields:
          - affectedRows
          - returning

---
kind: Command
version: v1
definition:
  name: UpdateUsers
  outputType: UpdateUsersResult!
  arguments:
    - name: returning
      type: "[String_1!]"
      description: Fields to return
    - name: set
      type: UsersSetInput!
      description: Values to set
    - name: where
      type: UsersBoolExp!
      description: Filter for rows to update
  source:
    dataConnectorName: my_pg
    dataConnectorCommand:
      procedure: update_users
  graphql:
    rootFieldName: updateUsers
    rootFieldKind: Mutation
  description: Update users

---
kind: CommandPermissions
version: v1
definition:
  commandName: UpdateUsers
  permissions:
    - role: admin
      allowExecution: true

