---
kind: ObjectType
version: v1
definition:
  name: UsersSetInput
  description: Input type for updating users
  fields:
    - name: createdAt
      type: TimestampWithoutTimeZoneSetInput
      description: New value wrapper for users.created_at
    - name: email
      type: TextSetInput
      description: New value wrapper for users.email
    - name: id
      type: IntegerSetInput
      description: New value wrapper for users.id
    - name: name
      type: TextSetInput
      description: New value wrapper for users.name
  graphql:
    typeName: UsersSetInput
    inputTypeName: UsersSetInputInput
  dataConnectorTypeMapping:
    - dataConnectorName: my_pg
      dataConnectorObjectType: users_set_input
      fieldMapping:
        createdAt:
          column:
            name: created_at
        email:
          column:
            name: email
        id:
          column:
            name: id
        name:
          column:
            name: name

---
