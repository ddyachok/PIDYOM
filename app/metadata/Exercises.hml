---
kind: Model
version: v2
definition:
  name: Exercises
  objectType: Exercises
  source:
    dataConnectorName: my_pg
    collection: exercises
  filterExpressionType: ExercisesBoolExp
  aggregateExpression: ExercisesAggExp
  orderByExpression: ExercisesOrderByExp
  graphql:
    selectMany:
      queryRootField: exercises
      subscription:
        rootField: exercises
    selectUniques:
      - queryRootField: exercisesById
        uniqueIdentifier:
          - id
        subscription:
          rootField: exercisesById
    filterInputTypeName: ExercisesFilterInput
    aggregate:
      queryRootField: exercisesAggregate
      subscription:
        rootField: exercisesAggregate

