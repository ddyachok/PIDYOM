# Server configuration
PORT=3001

# Neon Auth Configuration (for production)
# Get these values from your Neon project dashboard
NEON_PROJECT_ID=your-neon-project-id
NEON_AUTH_ISSUER=https://auth.neon.tech
NEON_JWKS_URI=https://auth.neon.tech/.well-known/jwks.json

# Development mode (leave empty to disable JWT verification for development)
# NEON_JWKS_URI=
